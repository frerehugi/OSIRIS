# Keeper Service — Umgebungsvariablen
# Kopiere diese Datei als ".env" und fülle die Werte aus.
# NIEMALS die echte .env-Datei in Git committen!

KEEPER_PRIVATE_KEY=0x_dein_private_key_hier

# Bei https://app.squidrouter.com/ beantragen. Solange hier "PENDING" steht,
# verweigert der Keeper den Start (siehe keeper/squidKeeper.ts).
SQUID_INTEGRATOR_ID=PENDING

# Adresse der DcaVaultFactory (siehe script/DeployFactory.s.sol). Der Keeper
# liest darüber alle Nutzer-Vaults (factory.getAllVaults()).
FACTORY_ADDRESS=0x_deine_factory_adresse_hier
