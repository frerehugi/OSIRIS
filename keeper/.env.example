# Keeper Service — Umgebungsvariablen
# Kopiere diese Datei als ".env" und fülle die Werte aus.
# NIEMALS die echte .env-Datei in Git committen!

KEEPER_PRIVATE_KEY=0x_dein_private_key_hier

# Bei https://app.squidrouter.com/ beantragen. Solange hier "PENDING" steht,
# verweigert der Keeper den Start (siehe keeper/squidKeeper.ts).
SQUID_INTEGRATOR_ID=PENDING

# Komma-getrennte Liste aller DcaVaultFactory-Adressen (siehe
# script/DeployFactory.s.sol). Der Keeper liest darüber alle Nutzer-Vaults
# (factory.getAllVaults()) — bei einem neuen Factory-Deploy (z.B. Contract-
# Upgrade) die neue Adresse ERGÄNZEN, nicht ersetzen, sonst verliert der
# Keeper die Vaults der alten Factory aus den Augen. Einzelne Adresse (alter
# Name FACTORY_ADDRESS) wird weiter als Fallback unterstützt.
FACTORY_ADDRESSES=0x_alte_factory_adresse,0x_neue_factory_adresse

# Optional — CELO-Auto-Refuel (siehe squidKeeper.ts autoRefuelCelo()). Ohne
# diese Variablen gelten die Defaults: 5 USD-Äquivalent Schwelle, 40 % Swap.
# KEEPER_REFUEL_THRESHOLD=5
# KEEPER_REFUEL_PCT_BPS=4000
